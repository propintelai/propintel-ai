VITE_API_BASE_URL=http://127.0.0.1:8000

# Public site origin used in Supabase password-reset emails (fallback: window.location.origin).
# Production example: https://www.propintel-ai.com
# Must match an allowed Redirect URL in Supabase → Authentication → URL Configuration.
# VITE_SITE_URL=https://www.propintel-ai.com

# Show “API Docs” in the navbar (links to VITE_API_BASE_URL/docs). Set to 1 only when the
# backend has DOCS_ENABLED=1. Omit in production so Swagger is not advertised in the UI.
# VITE_SHOW_API_DOCS=1

# Optional legacy API key fallback (used by some /auth routes and local OpenAPI testing)
# Leave blank in production if you only use Supabase JWT.
VITE_API_KEY=

# Mapbox public token used by the frontend
VITE_MAPBOX_TOKEN=
# Optional — defaults to Mapbox Standard (3D buildings). Override with e.g. mapbox://styles/mapbox/streets-v12
# VITE_MAPBOX_STYLE=mapbox://styles/mapbox/standard

# Supabase Auth — get both values from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

