# =============================================================================
# Staging frontend — copy to frontend/.env.staging (gitignored) and fill in.
#
# Run:  npm run dev:staging
#
# Vite loads (in order, later overrides earlier for the same key):
#   .env  →  .env.local  →  .env.staging  →  .env.staging.local
# Plain `npm run dev` does NOT load .env.staging — your normal dev is unchanged.
# =============================================================================

# Staging API (Railway or other host — must use https in real staging)
VITE_API_BASE_URL=https://your-staging-api.example.com

# Staging Supabase project (Project Settings → API) — same URL as backend SUPABASE_URL host
VITE_SUPABASE_URL=https://YOUR_STAGING_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=

# Optional — same as backend API_KEY if you use X-API-Key without a session
# VITE_API_KEY=

VITE_MAPBOX_TOKEN=
# VITE_MAPBOX_STYLE=mapbox://styles/mapbox/standard
