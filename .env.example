# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:PORT/DATABASE

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Internal API key (scripts, CI, Postman) ──────────────────────────────────
API_KEY=your-secret-api-key-here

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

# ── OpenAPI docs ──────────────────────────────────────────────────────────────
# /docs, /redoc, and /openapi.json are disabled by default.
# Set to 1 locally when you want Swagger UI. Keep 0 (or unset) in production.
# DOCS_ENABLED=1

# ── Logging ───────────────────────────────────────────────────────────────────
# Log verbosity: DEBUG | INFO | WARNING | ERROR (default: INFO)
# LOG_LEVEL=INFO

# ── Observability / Sentry ────────────────────────────────────────────────────
# Optional. When set, unhandled exceptions are captured with full request context.
# Get your DSN from https://sentry.io → Project → Settings → Client Keys.
# SENTRY_DSN=https://xxxx@oXXX.ingest.sentry.io/YYYY
# SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Reverse proxy (optional) ───────────────────────────────────────────────────
# Set to 1 when the API runs behind a load balancer / ingress that sets
# X-Forwarded-For. Enables correct client IP for rate-limit buckets and access
# logs. Do not enable on a directly exposed host — clients could spoof the header.
# TRUST_PROXY_HEADERS=1

# ── LLM settings ─────────────────────────────────────────────────────────────
LLM_TEMPERATURE=0.3
# Daily LLM call quotas per user tier. Set to 0 to disable the LLM for that tier.
LLM_QUOTA_FREE=10
LLM_QUOTA_PAID=200

# ── Supabase Auth ─────────────────────────────────────────────────────────────
# Same project URL as VITE_SUPABASE_URL (e.g. https://YOUR_PROJECT.supabase.co).
# Required for RS256/ES256 asymmetric JWT verification via JWKS.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Required for HS256 symmetric JWT verification (Supabase Dashboard → Project Settings → API → JWT Secret).
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-dashboard

# ── Admin users ───────────────────────────────────────────────────────────────
# Comma-separated Supabase user UUIDs granted admin access regardless of profiles.role.
# Checked before any DB query, so works even before a profile row exists.
ADMIN_USER_IDS=00000000-0000-0000-0000-000000000000

# ── Mapbox ────────────────────────────────────────────────────────────────────
# The admin dashboard compares in-app recorded Mapbox usage against this cap.
# Mapbox does not expose account totals via API — adjust if your plan differs.
# MAPBOX_MONTHLY_FREE_REQUEST_CAP=100000

# ── ML artifacts ──────────────────────────────────────────────────────────────
# The repo commits ml/artifacts/metadata/ but NOT the trained .pkl binaries.
# Point this at a mounted volume or a downloaded artifact bundle root.
# ML_ARTIFACT_ROOT=/app

# ── Database pool ─────────────────────────────────────────────────────────────
# Tune when running under high concurrency. Defaults: pool_size=5, max_overflow=10.
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10

# ── Frontend — create frontend/.env with these values ─────────────────────────
# VITE_API_BASE_URL=http://127.0.0.1:8000
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# VITE_API_KEY=your-secret-api-key-here   (must match API_KEY above; only needed without a session)
# VITE_MAPBOX_TOKEN=pk.your-mapbox-public-token-here
