# =============================================================================
# Staging backend — copy to .env.staging (gitignored) at repo root.
#
# Use with Docker:
#   docker run --rm -p 8000:8000 --env-file .env.staging propintel-ai:latest
#
# Or locally (after: set -a && source .env.staging && set +a):
#   uvicorn backend.app.main:app --reload
#
# This file is NOT loaded automatically; it never replaces your normal .env.
# =============================================================================

DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:PORT/DATABASE

SUPABASE_URL=https://YOUR_STAGING_PROJECT.supabase.co
SUPABASE_JWT_SECRET=

OPENAI_API_KEY=sk-...
API_KEY=

# Browser origin when you run the SPA locally against staging API (add Vercel URL when you have it)
CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

SENTRY_ENVIRONMENT=staging
# SENTRY_DSN=
# SENTRY_RELEASE=
# SENTRY_TRACES_SAMPLE_RATE=0.1

TRUST_PROXY_HEADERS=1
DOCS_ENABLED=1
LOG_LEVEL=INFO

ADMIN_USER_IDS=
